{
  "info": {
    "name": "blog-server-go rag smoke",
    "description": "Plan 15 RAG 冒烟。先 `go run scripts/dev_login.go --token-only` 获取 token。gateway 默认 8000。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "rag status (public)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/rag/status"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "const j = pm.response.json();",
            "pm.test('status ok', () => pm.expect(j.code).to.eql(200));",
            "pm.test('has chunkCount', () => pm.expect(j.data).to.have.property('chunkCount'));"
          ]
        }
      }]
    },
    {
      "name": "rag quota",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/v1/rag/quota"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "const j = pm.response.json();",
            "pm.test('quota ok', () => pm.expect(j.code).to.eql(200));",
            "pm.test('has limit', () => pm.expect(j.data.limit).to.be.at.least(1));"
          ]
        }
      }]
    },
    {
      "name": "admin rag stats",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/v1/admin/rag/stats"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "const j = pm.response.json();",
            "pm.test('stats ok', () => pm.expect(j.code).to.eql(200));"
          ]
        }
      }]
    },
    {
      "name": "admin rag index-jobs",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/v1/admin/rag/index-jobs?page=1&pageSize=10"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "const j = pm.response.json();",
            "pm.test('jobs ok', () => pm.expect(j.code).to.eql(200));",
            "pm.test('has list', () => pm.expect(Array.isArray(j.data.list)).to.be.true);"
          ]
        }
      }]
    }
  ]
}
