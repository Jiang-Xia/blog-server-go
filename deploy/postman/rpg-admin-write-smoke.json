{
  "info": {
    "name": "blog-server-go rpg admin write smoke",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "health",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/health" },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('code 200', () => pm.expect(pm.response.json().code).to.eql(200));"] } }]
    },
    {
      "name": "admin rpg stats",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/v1/admin/rpg/stats"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('stats ok', () => pm.expect(pm.response.json().code).to.eql(200));"] } }]
    },
    {
      "name": "admin rpg achievements list",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/v1/admin/rpg/achievements?page=1&pageSize=5"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('achievements ok', () => pm.expect(pm.response.json().code).to.eql(200));"] } }]
    },
    {
      "name": "admin rpg quests list",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/v1/admin/rpg/quests?page=1&pageSize=5"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('quests ok', () => pm.expect(pm.response.json().code).to.eql(200));"] } }]
    }
  ]
}
