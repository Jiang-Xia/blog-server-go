# 复制为 deploy.local.env（已 gitignore，勿提交）

DEPLOY_HOST=your-server-ip
DEPLOY_USER=ubuntu
DEPLOY_PORT=22
DEPLOY_PASSWORD=your-password-here
DEPLOY_HOSTKEY=ssh-ed25519 255 SHA256:your-fingerprint-here
DEPLOY_REMOTE_DIR=/opt/jxapp/server/blog-server-go
# 与 Nest 共用上传目录（Nginx 直出 /static/uploads）
DEPLOY_PUBLIC_DIR=/opt/jxapp/server/blog-server/public
# 部署模式：monolith（生产主路径 :8000）| microservices（四微服务 gateway :8000，与单体二选一）
# DEPLOY_MODE=monolith
DEPLOY_PM2_APPS=BlogGo_User,BlogGo_Blog,BlogGo_Rpg,BlogGo_Gateway
DEPLOY_ECOSYSTEM_FILE=ecosystem.config.js
# 单体部署示例（与微服务同一 remote 目录与 env.production，仅改以下三行）：
# DEPLOY_MODE=monolith
# DEPLOY_PM2_APPS=BlogGo_Monolith
# DEPLOY_ECOSYSTEM_FILE=ecosystem.monolith.config.js
DEPLOY_TAR_NAME=blog-server-go.tar.gz
# DEPLOY_BACKUP_KEEP=5
# DEPLOY_RELEASE_KEEP=5
# 真实生产 env（gitignore，部署前自动同步为 configs/*.yaml）
DEPLOY_ENV_FILE=deploy/pm2/env.production
DEPLOY_CONFIG_DIR=deploy/pm2/configs
