# 生产环境配置模板（可提交 Git，无真实密钥）
# 首次：复制为 deploy/pm2/env.production（gitignore）并填写真实值
#   cp deploy/pm2/env.production.example deploy/pm2/env.production
# 若已有 Nest 部署，可一次性从 blog-server 拷贝对照（之后在本仓库独立维护，部署不依赖 blog-server）：
#   cp ../blog-server/deploy/pm2/env.production deploy/pm2/env.production
#
# 格式与 blog-server deploy/pm2/env.production 一致；deploy.ps1 部署前自动生成为四服务 configs/*.yaml

app_desc = <==生产环境==>

# Database
db_type = mysql
db_host = 127.0.0.1
db_port = 3306
db_username =
db_password =
db_database = x_my_blog
db_synchronize = false
db_logging = 'error'

# Redis
redis_host = 127.0.0.1
redis_port = 6379
redis_db = 1

# Server（Go gateway 对外 :8000；下列项供 CORS / 回调 URL 等映射）
serve_port = 5000
serve_apiPath = api/v1
serve_baseUrl = https://your-domain.example

# CORS（英文逗号分隔；本地联调 Go 线上时追加 localhost:5050/9000，与 blog-server/deploy/nginx/conf.d/main.conf 一致）
serve_corsOrigins = https://your-domain.example,https://admin.your-domain.example,http://localhost:5050,http://127.0.0.1:5050,http://localhost:9000,http://127.0.0.1:9000

# Auth (JWT)
auth_jwtSecret =

swagger_enabled = false

throttle_ttl = 60000
throttle_limit = 100

log_dir = ./logs
log_maxFiles = 14d
log_maxSize = 20m
shutdown_timeout = 10000

file_filePath = ./public/uploads/

serve_logLevels = log,error,warn
app_openMsgLog = false
app_closeMsgBodyLog = true

app_aesKey =
app_aesIv =

app_gaoDeMapApiKey =
app_emailHost =
app_emailPort = 465
app_emailUser =
app_emailPass =
app_blogHome = https://your-domain.example
app_githubClientId =
app_githubClientSecret =
app_githubCallbackUrl = https://your-domain.example/api/v1/user/auth/github/callback

app_tongjiRefreshToken =
app_tongjiClientId =
app_tongjiClientSecret =

pay_alipayAppId =
pay_alipayPrivateKey =
pay_alipayPublicKey =
pay_alipayGateway = https://openapi.alipay.com/gateway.do
pay_alipaySignType = RSA2
pay_alipayTimeout = 5000
pay_alipayNotifyUrl = https://your-domain.example/api/v1/pay/notice
pay_alipayReturnUrl =
pay_alipayMiniCashierPage = packageB/pages/business/pay/all-pay/all-pay
pay_wechatAppId =
pay_wechatSecret =

# RAG（Go 服务暂未消费，保留字段便于与 Nest env 格式一致）
rag_enabled = false
rag_api_key =
rag_api_base_url = https://api.deepseek.com/v1
rag_embedding_api_key =
rag_embedding_api_base_url = https://api.siliconflow.cn/v1
rag_embedding_model = BAAI/bge-large-zh-v1.5
rag_chat_model = deepseek-chat
rag_daily_query_limit = 20
rag_top_k = 6
rag_allow_local_fallback = true
