    "definitions": {
        "apidoc.ErrorBody": {
            "type": "object",
            "properties": {
                "bizCode": {
                    "type": "integer",
                    "example": 40001
                },
                "code": {
                    "type": "integer",
                    "example": 40001
                },
                "message": {
                    "type": "string",
                    "example": "参数错误"
                }
            }
        },
        "apidoc.SuccessBody": {
            "type": "object",
            "properties": {
                "bizCode": {
                    "type": "integer",
                    "example": 200
                },
                "code": {
                    "type": "integer",
                    "example": 200
                },
                "data": {},
                "message": {
                    "type": "string",
                    "example": "success"
                }
            }
        }
